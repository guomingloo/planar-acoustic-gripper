set_global_assignment -name IP_TOOL_NAME "ALTSQRT"
set_global_assignment -name IP_TOOL_VERSION "25.1"
set_global_assignment -name IP_GENERATED_DEVICE_FAMILY "{Cyclone IV E}"
set_global_assignment -name VERILOG_FILE [file join $::quartus(qip_path) "altsqrt_28i_6c.v"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "altsqrt_28i_6c_bb.v"]
